{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Redis Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_up", "legendFormat": "Up" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }],
          "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        },
        "overrides": []
      }
    },
    {
      "title": "Connected Clients",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_connected_clients", "legendFormat": "Clients" }],
      "fieldConfig": { "defaults": { "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true } }, "overrides": [] }
    },
    {
      "title": "Used Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "redis_memory_used_bytes", "legendFormat": "Used" },
        { "expr": "redis_memory_max_bytes > 0", "legendFormat": "Max" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true } }, "overrides": [] }
    },
    {
      "title": "Hit Rate %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "100 * redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total)", "legendFormat": "Hit Rate %" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 80, "color": "yellow" }, { "value": 95, "color": "green" }] }
        },
        "overrides": []
      }
    },
    {
      "title": "Commands/sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "Commands/sec" }],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true } }, "overrides": [] }
    },
    {
      "title": "Keys per DB",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_db_keys", "legendFormat": "db{{db}}" }],
      "fieldConfig": { "defaults": { "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true } }, "overrides": [] }
    },
    {
      "title": "Network Input/Output",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(redis_net_input_bytes_total[5m])", "legendFormat": "Input" },
        { "expr": "rate(redis_net_output_bytes_total[5m])", "legendFormat": "Output" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true } }, "overrides": [] }
    },
    {
      "title": "Connected Clients (by IP)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_connected_clients", "legendFormat": "Connected" }],
      "fieldConfig": { "defaults": { "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true } }, "overrides": [] }
    }
  ],
  "schemaVersion": 39,
  "tags": ["redis"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Redis",
  "uid": "redis-overview",
  "version": 1
}

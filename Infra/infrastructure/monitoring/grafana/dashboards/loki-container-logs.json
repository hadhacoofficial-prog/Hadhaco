{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (service_name) (rate({job=\"docker\"} |~ \"(?i)(error|exception|critical|fatal)\" [$__auto]))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "title": "Container Logs Rate (errors)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 20,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{job=\"docker\"} |= ``",
          "legendFormat": ""
        }
      ],
      "title": "All Container Logs",
      "type": "logs"
    }
  ],
  "schemaVersion": 39,
  "tags": [
    "loki",
    "logs"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "text": "Loki",
          "value": "Loki"
        },
        "name": "DS_LOKI",
        "query": "loki",
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": "label_values({job=\"docker\"}, service_name)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Container Logs"

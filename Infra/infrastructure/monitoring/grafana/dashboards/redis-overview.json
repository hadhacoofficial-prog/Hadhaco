          "expr": "redis_up",
          "legendFormat": "Up"
        }
      ],
      "title": "Redis Up",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 15,

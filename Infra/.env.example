# =============================================================================
# Hadha.co — Environment Configuration
# =============================================================================
# Copy this file to .env.production on the server and fill in values.
# NEVER commit this file with real secrets.
#
# See docs/SECRETS.md for the complete guide.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_IP=
SERVER_USER=deploy
DOMAIN=hadha.co
ADMIN_EMAIL=admin@hadha.co

# ── GHCR / Docker Registry ───────────────────────────────────────────────────
GHCR_TOKEN=
GHCR_USERNAME=hadhacoofficial-prog

# ── Application Images (set by CI) ───────────────────────────────────────────
BACKEND_IMAGE=ghcr.io/hadhacoofficial-prog/hadha-backend:latest
STOREFRONT_IMAGE=ghcr.io/hadhacoofficial-prog/hadha-storefront:latest
ADMIN_IMAGE=ghcr.io/hadhacoofficial-prog/hadha-admin:latest

# ── Application Backend ──────────────────────────────────────────────────────
APP_NAME=Hadha.co
APP_ENV=production
APP_DEBUG=false
SECRET_KEY=
ENCRYPTION_KEY=
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=https://api.hadha.co
API_V1_PREFIX=/api/v1

# ── Database (Supabase) ──────────────────────────────────────────────────────
DATABASE_URL=
ALEMBIC_DATABASE_URL=
DATABASE_POOL_SIZE=3
DATABASE_MAX_OVERFLOW=1
DATABASE_POOL_TIMEOUT=30

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@hadha-redis:6379/0
REDIS_CACHE_TTL=300
REDIS_RATE_LIMIT_TTL=60

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=hadha-media
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.hadha.co
CLOUDFLARE_R2_ENDPOINT=

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@hadha.co
RESEND_TO_EMAIL=admin@hadha.co
EMAIL_FROM=noreply@hadha.co
EMAIL_REPLY_TO=support@hadha.co
EMAIL_FROM_NAME=Hadha.co

# ── Payments (Razorpay) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR

# ── Frontend URLs ────────────────────────────────────────────────────────────
FRONTEND_URL=https://hadha.co
ADMIN_URL=https://admin.hadha.co

# ── Auth Callbacks ───────────────────────────────────────────────────────────
SUPABASE_AUTH_REDIRECT_URL=https://hadha.co/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Error Tracking (GlitchTip) ───────────────────────────────────────────────
GLITCHTIP_DSN=
GLITCHTIP_FRONTEND_DSN=
GLITCHTIP_SECRET_KEY=
GLITCHTIP_DB_PASSWORD=

# ── Monitoring Credentials ───────────────────────────────────────────────────
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=
MONITORING_USERNAME=hadha-admin
MONITORING_PASSWORD=
REDIS_UI_USERNAME=hadha-admin
REDIS_UI_PASSWORD=
DOZZLE_USERNAME=hadha-admin
DOZZLE_PASSWORD=

# ── Rate Limits ──────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH=10
RATE_LIMIT_API=200
RATE_LIMIT_UPLOAD=20
RATE_LIMIT_WEBHOOK=500

# ── WhatsApp (optional) ──────────────────────────────────────────────────────
WHATSAPP_ENABLED=false
WHATSAPP_BUSINESS_PHONE=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0

# ── Delivery Service ─────────────────────────────────────────────────────────
DELIVERY_ONE_API_KEY=
DELIVERY_ONE_API_URL=

# ── Business Settings ────────────────────────────────────────────────────────
FREE_SHIPPING_THRESHOLD=999
SHIPPING_FLAT_RATE=99
TAX_RATE_GST=3
SELLER_STATE=Maharashtra
SELLER_GSTIN=
LOW_STOCK_THRESHOLD=5
ORDER_NUMBER_PREFIX=HD
INVOICE_NUMBER_PREFIX=INV
ADMIN_ALERT_EMAIL=admin@hadha.co

# ── Background Workers ───────────────────────────────────────────────────────
WORKER_ORDER_SYNC_INTERVAL=300
WORKER_INVENTORY_CHECK_INTERVAL=600
WORKER_DELIVERY_CHECK_INTERVAL=900
REVIEW_REMINDER_DELAY_HOURS=48

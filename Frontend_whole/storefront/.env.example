# Copy to `.env` and fill in real values. Never hardcode these in source.

# ── Backend API (FastAPI) ─────────────────────────────────────────────────────
# VITE_API_BASE_URL — baked into the client bundle at build time.
# Must be reachable from the user's browser. Keep localhost:8000 for local dev.
# Production: https://api.hadha.co/api/v1  (injected via Dockerfile ARG at build)
VITE_API_BASE_URL="http://localhost:8000/api/v1"

# SERVER_API_BASE_URL — runtime env var read by the Nitro SSR server only.
# Never exposed to the browser. Points directly to the backend over the
# Docker-internal network, bypassing nginx and avoiding external round-trips.
# Production:  set via docker-compose environment (http://hadha-backend:8000/api/v1)
# Development: leave unset — falls back to VITE_API_BASE_URL default.
# SERVER_API_BASE_URL="http://localhost:8000/api/v1"

# ── Supabase (client-side, Vite build-time replacement) ──────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
VITE_SUPABASE_PROJECT_ID="your-project"

# ── Supabase (SSR / server-side, read via process.env) ───────────────────────
# These are read by the Nitro SSR server — not exposed to the browser bundle.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
SUPABASE_SERVICE_ROLE_KEY="eyJhb..."

# ── Error Tracking (GlitchTip/Sentry) ───────────────────────────────────────
# Client-side DSN — baked into the JS bundle. Set to empty to disable.
VITE_SENTRY_DSN=""
# Server-side DSN — read by the Nitro SSR server via process.env.
SENTRY_DSN=""

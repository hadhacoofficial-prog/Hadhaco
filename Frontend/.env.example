# Copy to `.env` and fill in real values. Never hardcode these in source.

# ── Backend API (FastAPI) ─────────────────────────────────────────────────────
# VITE_ vars are baked into the client-side bundle at build time.
# This URL must be reachable from the user's *browser*, so keep it at
# localhost:8000 even when running in Docker (port 8000 is mapped to the host).
VITE_API_BASE_URL="http://localhost:8000/api/v1"

# ── Supabase (client-side, Vite build-time replacement) ──────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
VITE_SUPABASE_PROJECT_ID="your-project"

# ── Supabase (SSR / server-side, read via process.env) ───────────────────────
# These are read by the Nitro SSR server — not exposed to the browser bundle.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
SUPABASE_SERVICE_ROLE_KEY="eyJhb..."
